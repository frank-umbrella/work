rules_version = '2';

// Umbrella Automation — Watchtower (fleet monitoring)
// Firestore security rules.
//
// Two principal types — and they look very different here:
//
//   1. MSP admins — Umbrella employees, members of /msp_admins/{uid}.
//                   Use Firebase Auth (Google provider). Read every
//                   agent's status + history, write per-agent config
//                   (kill switches, webhook URLs, notes).
//
//   2. Watchtower agents — Windows services on client PCs. They do NOT
//                   authenticate as Firebase users. They POST check-ins
//                   to watchtower-worker, which validates a per-install
//                   shared-secret token and then writes to Firestore via
//                   a service account (jose JWT, same pattern as
//                   usage-worker and stocks-worker). Service-account
//                   writes bypass these rules entirely.
//
// Because agents never authenticate to Firestore directly, every
// `/agents/...` write rule here is `if false`. The only writers are
// admins (via the dashboard, for config) and the worker (via service
// account, for status + history).
//
// Admin membership: any signed-in Google account whose verified email
// ends with @umbrellaautomation.com. No per-user database entries to
// maintain — adding/removing admins is a Google Workspace action.
//
// Trade-off: everyone on the domain gets full read/write across the
// whole fleet. If we ever need viewer-only or per-client scoping,
// reintroduce a roster doc and gate on that instead.

service cloud.firestore {
  match /databases/{database}/documents {

    // -------- helpers --------

    function isSignedIn() {
      return request.auth != null;
    }

    function isMSPAdmin() {
      return isSignedIn()
        && request.auth.token.email_verified == true
        && request.auth.token.email.matches('.*@umbrellaautomation[.]com');
    }

    // -------- /users/{uid} --------
    // Per-user preferences stored by the dashboard (e.g. saved Endpoints
    // column layout). Each MSP admin reads and writes ONLY their own doc;
    // nobody can touch another user's preferences even though all admins
    // have full fleet access.
    //
    // Doc shape: { endpointColumns: ["client","hostname",...] }
    // Written by setSelectedFleetColumns(), read by loadUserColumnPrefs().
    match /users/{uid} {
      allow get, create, update, delete: if isMSPAdmin() && request.auth.uid == uid;
    }

    // -------- /activity/{eventId} --------
    // Append-only audit log of fleet events: agent first-seen, IP changes,
    // OMSA warnings, backup failures, admin actions (client added/deleted,
    // token generated/revoked, host reassigned, decommissioned), etc.
    //
    // Read: admins (the Activity tab in the dashboard).
    // Write: admins (dashboard logs admin actions) AND worker via service
    //        account (which bypasses these rules anyway, for agent events).
    // Update/delete: admins, so a typo can be cleaned up.
    match /activity/{eventId} {
      allow get, list: if isMSPAdmin();
      allow create, update, delete: if isMSPAdmin();
    }

    // -------- /settings/{key} --------
    // Global settings docs. Currently only /settings/webhook is used —
    // it holds the master webhook URL that all per-agent webhook
    // events post to. The per-agent webhookEnabled toggle still gates
    // whether THAT agent's events fire; the URL itself lives here so
    // it's set once for the whole fleet, not per host.
    //
    // Admin RW. Worker reads via service account (bypasses these rules).
    match /settings/{key} {
      allow get, list: if isMSPAdmin();
      allow create, update, delete: if isMSPAdmin();
    }

    // -------- /clients/{clientId} --------
    // Client roster (the MSP's customers). Dashboard creates/manages
    // these from the "+ New install" flow. Admins-only — no agent or
    // public read.
    match /clients/{clientId} {
      allow get, list: if isMSPAdmin();
      allow create, update, delete: if isMSPAdmin();
    }

    // -------- /install_tokens/{tokenHash} --------
    // Per-client install tokens. Doc id is the SHA-256 hex digest of the
    // raw token; the raw token itself is never stored (shown once at
    // generation time, entered at install time in the agent wizard).
    //
    // Write: admins only (from the dashboard).
    // Read: admins (to manage). The worker reads via service account
    //       (bypasses these rules) to validate each check-in.
    //
    // Note on listing: the dashboard lists tokens by clientId via a
    // where() query, which requires per-doc read evaluation. List is
    // admin-only so attackers can't enumerate token hashes.
    match /install_tokens/{tokenHash} {
      allow get, list: if isMSPAdmin();
      allow create, update, delete: if isMSPAdmin();
    }

    // -------- /agents/{pcId} --------
    // Per-PC status document. pcId is a stable UUID generated at install
    // time by the agent — NOT the hostname (hostnames can change /
    // collide across clients).
    //
    // Read: MSP admins only.
    // Write: never directly — only the watchtower-worker writes here,
    //        via service account (which bypasses these rules).
    match /agents/{pcId} {
      allow get, list: if isMSPAdmin();
      allow create, update, delete: if false;

      // -------- /agents/{pcId}/config/{configId} --------
      // Per-agent control plane. The "current" doc carries:
      //   enabled        (master kill switch)
      //   emailEnabled   (suppress alert emails but keep monitoring)
      //   webhookEnabled (suppress webhook POSTs)
      //   webhookUrl     (where to POST on IP change)
      //   notes          (MSP-internal note about this host)
      //   uninstall      (one-shot: agent self-removes on next check-in)
      //
      // The agent reads this via the worker on every check-in, so flips
      // take effect within one check cycle (24h by default).
      //
      // Admins write this from the dashboard. Worker reads (service
      // account, bypasses rules). No one else touches it.
      //
      // Immutable fields on update: we don't enforce any here because
      // every field is intentionally editable.
      match /config/{configId} {
        allow get, list: if isMSPAdmin();
        allow create, update, delete: if isMSPAdmin();
      }

      // -------- /agents/{pcId}/history/{checkinId} --------
      // Rolling check-in history. Worker writes one doc per check-in
      // capturing the external IP, whether anything changed, and a
      // small delta. Retain ~90 days (cleanup runs in a separate
      // scheduled worker — not built yet).
      //
      // Read: MSP admins only. Write: service-account-only (false here).
      match /history/{checkinId} {
        allow get, list: if isMSPAdmin();
        allow create, update, delete: if false;
      }
    }
  }
}
