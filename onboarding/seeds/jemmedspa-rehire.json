{
  "_about": "JEM Medspa — Rehire form. For employees returning after previously leaving the company. Asks the same baseline as New Hire plus a Rehire-specific section (prior employment + accounts to restore vs reset). Paste the 'schema' object's contents into the schema editor in the app.",
  "formMeta": {
    "formId": "rehire",
    "kind": "rehire",
    "title": "Rehire",
    "description": "Submit a request to onboard an employee returning to JEM Medspa after a prior departure."
  },
  "schema": {
    "pages": [
      {
        "fields": [
          { "id": "hireDate", "type": "date", "label": "Rehire Start Date", "required": true },
          { "id": "employeeId", "type": "text", "label": "Employee ID / Number (new or restored)", "required": true,
            "help": "Use the previous Employee ID if you want to restore the original record; otherwise issue a new one." },
          { "id": "employmentType", "type": "select", "label": "Part-Time / Full-Time", "required": true,
            "options": ["Part-Time", "Full-Time"] },
          { "id": "firstName", "type": "text", "label": "First Name", "required": true },
          { "id": "lastName", "type": "text", "label": "Last Name", "required": true },
          { "id": "preferredEmail", "type": "email", "label": "Preferred Email", "required": true,
            "placeholder": "firstname.lastname@jemmedspa.com",
            "help": "If you want to reactivate the prior work email, enter it here. Otherwise the new convention is first.last@jemmedspa.com." },
          { "id": "alternateEmail", "type": "email", "label": "Personal Email",
            "help": "Personal email so we can send the welcome packet before the work account is reactivated or set up." }
        ]
      },
      {
        "section": "Rehire — Prior Employment",
        "fields": [
          { "id": "previousLastDay", "type": "date", "label": "Previous Last Day Worked",
            "help": "When did this employee originally leave?" },
          { "id": "previousEmployeeId", "type": "text", "label": "Previous Employee ID",
            "help": "Leave blank if unknown — IT can look it up from records." },
          { "id": "previousTitle", "type": "text", "label": "Previous Title" },
          { "id": "previousManagerName", "type": "text", "label": "Previous Manager Name" },
          { "id": "rehireReason", "type": "select", "label": "Reason for Rehire", "required": true,
            "options": ["Returning to same role", "Returning to different role", "Seasonal / contract return", "Other"] },
          { "id": "rehireReasonOther", "type": "text", "label": "Reason — Other",
            "showIf": { "rehireReason": "Other" } },
          { "id": "restorePriorAccounts", "type": "radio", "label": "Restore Prior Accounts?", "required": true,
            "options": ["Yes — reactivate as much as possible", "No — fresh start with new accounts", "Mixed — see notes"],
            "help": "Email mailbox, Microsoft 365 license, OneDrive contents, prior group memberships, etc. If accounts were fully deprovisioned, restoring may not be possible — IT will confirm." },
          { "id": "restoreNotes", "type": "textarea", "label": "Restore Notes",
            "showIf": { "restorePriorAccounts": "Mixed — see notes" } }
        ]
      },
      {
        "fields": [
          { "id": "department", "type": "select", "label": "Department", "required": true,
            "options": [
              { "label": "Accounting", "value": "Accounting" },
              { "label": "Admin", "value": "Admin" },
              { "label": "Human Resources", "value": "hr" },
              { "label": "Other", "value": "Other" }
            ] },
          { "id": "departmentOther", "type": "text", "label": "Other Department",
            "showIf": { "department": "Other" }, "required": true,
            "help": "Add department if not listed in the dropdown menu." },
          { "id": "title", "type": "select", "label": "Employee Title", "required": true,
            "options": ["- Other"] },
          { "id": "titleOther", "type": "text", "label": "Employee Title - Other",
            "showIf": { "title": "- Other" }, "required": true,
            "help": "ie. Associate, Manager, Staff Accountant" },
          { "id": "managerEmail", "type": "email", "label": "Direct Manager's Email", "required": true }
        ]
      },
      {
        "section": "User Specific Access",
        "fields": [
          { "id": "emailRequired", "type": "radio", "label": "Email Account Required", "required": true,
            "options": ["Yes", "No"] },
          { "id": "teamsGroups", "type": "checkboxes", "label": "Teams / Microsoft 365 Groups", "required": true,
            "options": [
              "dext@jemmedspa.com",
              "leadership1@jemmedspa.com",
              "jemmedspa@jemmedspa.com",
              "jemmedspaelmhurst@jemmedspa.com",
              "managercallgroup@jemmedspa.com",
              "opccs@jemmedspa.com",
              "orlandparkjems@jemmedspa.com",
              "qrcodes@jemmedspa.com",
              "None"
            ],
            "help": "Used for collaboration and communication within Microsoft Teams and shared resources in 365." },
          { "id": "distributionLists", "type": "checkboxes", "label": "Distribution Lists / Groups", "required": true,
            "options": [
              "allemployees@jemmedspa.com",
              "aestheticians@jemmedspa.com",
              "clientcoordiantors@jemmedspa.com",
              "elmemployees@jemmedspa.com",
              "info@jemmedspa.com",
              "leadership@jemmedspa.com",
              "munemployees@jemmedspa.com",
              "nurses@jemmedspa.com",
              "None"
            ],
            "help": "Used for sending emails to multiple users at once." },
          { "id": "sharedMailboxes", "type": "checkboxes", "label": "Shared / Delegate Mailboxes", "required": true,
            "options": [
              "customerservice@jemmedspa.com",
              "education@jemmedspa.com",
              "elmhurst@jemmedspa.com",
              "elmhurst.billing@jemmedspa.com",
              "elmhurst.ordering@jemmedspa.com",
              "munster@jemmedspa.com",
              "munster.billing@jemmedspa.com",
              "munster.ordering@jemmedspa.com",
              "op.billing@jemmedspa.com",
              "op.ordering@jemmedspa.com",
              "orlandpark@jemmedspa.com",
              "None"
            ],
            "help": "Mailboxes with shared access — users can be added as delegates to view or send from these inboxes." }
        ]
      },
      {
        "section": "Onboarding",
        "fields": [
          { "id": "workstation", "type": "radio", "label": "Employee Primary PC Workstation", "required": true,
            "options": ["Assigned PC & Desk", "Public Workstation", "Purchase New Workstation", "Same Work Station as Past Employee", "Reuse Their Previous Workstation"] },
          { "id": "pastEmployeeName", "type": "name", "label": "Past Employee Name",
            "showIf": { "workstation": "Same Work Station as Past Employee" } },
          { "id": "computerName", "type": "text", "label": "Computer Name",
            "showIf": { "workstation": ["Assigned PC & Desk", "Same Work Station as Past Employee", "Reuse Their Previous Workstation"] } },
          { "id": "softwareApproval", "type": "checkboxes", "label": "Software Purchase Approval",
            "options": ["Microsoft 365 Office License"],
            "help": "If user needs access to any software, please approve purchase requests for software." },
          { "id": "pcPurchaseApproval", "type": "radio", "label": "PC Purchase Approval",
            "options": ["Approved", "Denied"],
            "showIf": { "workstation": "Purchase New Workstation" }, "required": true },
          { "id": "pcPurchaseDetails", "type": "textarea", "label": "PC Purchase Request Details",
            "showIf": { "workstation": "Purchase New Workstation" }, "required": true },
          { "id": "notes", "type": "textarea", "label": "Notes" }
        ]
      }
    ]
  }
}
