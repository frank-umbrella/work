rules_version = '2';

// Umbrella Automation — Incident Response
// SNIPPET ONLY — not deployed standalone.
//
// The Incident Response app shares the onboarding-a563d Firebase project
// with the onboarding app. Firebase allows only one Firestore rules file
// per project, so the rules below are merged into ../onboarding/firestore.rules
// (which is the deployed source of truth). This file is kept here as a
// reviewer-friendly excerpt of just the incident-specific rules.
//
// The functions isMSPAdmin() and managerDoc() are defined in the merged
// file. The TL;DR: only members of /msp_admins/{uid} (Umbrella employees)
// may read or write any /incidents data. Managers (external client
// employees) get no access at all to the incident system.

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- /incidents/{incidentId} ----------
    // Open incidents on MSP clients. Any MSP admin can create, read,
    // update, and delete. Original attribution (createdBy, createdAt) is
    // immutable. Timeline subcollection below is append-only.
    match /incidents/{incidentId} {
      allow read: if isMSPAdmin();

      allow create: if isMSPAdmin()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdByEmail == request.auth.token.email;

      allow update: if isMSPAdmin()
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdByEmail == resource.data.createdByEmail
        && request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if isMSPAdmin();

      // ----- /incidents/{id}/timeline/{eventId} -----
      // Append-only audit log: status changes, severity / assignee changes,
      // comments, file uploads, file removals.
      match /timeline/{eventId} {
        allow read: if isMSPAdmin();
        allow create: if isMSPAdmin()
          && request.resource.data.byUid == request.auth.uid
          && request.resource.data.byEmail == request.auth.token.email;
        allow update, delete: if false;
      }
    }
  }
}
